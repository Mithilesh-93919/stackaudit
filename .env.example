# Environment Variables — StackAudit
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to git.

# ── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=StackAudit

# ── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic (AI executive summary) ──────────────────────────────────────
# Required for AI-generated audit summaries (claude-haiku-4-5).
# If absent, the deterministic template summary is used as a fallback —
# the app remains fully functional without this key.
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── OpenAI (optional — reserved for future features) ──────────────────────
# Not currently used. The audit engine is rules-based, not LLM-driven.
# OPENAI_API_KEY=

# ── Email (Resend transactional) ───────────────────────────────────────────
# Required for sending audit confirmation emails via POST /api/leads.
# If absent, leads are still saved to Supabase — only email delivery is skipped.
# Get your key at: https://resend.com/api-keys
# Sender domain must be verified in Resend before emails will deliver.
RESEND_API_KEY=

# ── Analytics ──────────────────────────────────────────────────────────────
# Optional — used for product analytics. App works without these.
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
